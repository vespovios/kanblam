# Dev defaults — safe to commit. For production, copy this file to .env.prod,
# replace all <openssl rand ...> placeholders with real values, and chmod 600.
# NEVER commit .env.prod.

# App
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000
APP_URL=http://localhost:3000
# Auth.js v5: required when NODE_ENV=production so sign-in routes accept
# requests from the configured host (Compose defaults this to true; override
# only if you specifically want host validation enabled).
AUTH_TRUST_HOST=true
CRON_SECRET=replace-with-openssl-rand-base64-32
# Dev only: mirror of CRON_SECRET so the "Generate now" button on /recurring can
# call the cron endpoint without a separate scheduler. NEVER set in prod.
NEXT_PUBLIC_CRON_SECRET=replace-with-openssl-rand-base64-32

# Database
POSTGRES_PASSWORD=tasker
DATABASE_URL=postgresql://tasker:tasker@localhost:5432/tasker?schema=public

# Email (dev: MailHog on localhost; prod: Resend SMTP)
# 127.0.0.1, not `localhost`: Node prefers the IPv6 ::1 for localhost, and
# Docker-VM port forwarding (Colima etc.) often only answers on IPv4 —
# `localhost` gives ECONNREFUSED ::1 while the container looks healthy.
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM="KanBlam <noreply@kanblam.local>"

# Workspace seed (used only by prisma seed on first run)
WORKSPACE_NAME=Peter's Workspace
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
ADMIN_NAME=Admin

# --- Production-only (leave empty in dev .env) ---
# Second seed user (creates a MEMBER alongside ADMIN). Leave SEED_MEMBER_EMAIL
# empty to skip — the dev seed should leave these unset.
SEED_MEMBER_EMAIL=
SEED_MEMBER_PASSWORD=
SEED_MEMBER_NAME=

# Cloudflare Tunnel — token from CF Zero Trust → Networks → Tunnels →
# "Install connector"
CF_TUNNEL_TOKEN=

# Backups — host path of the UGREEN NAS mount (bind-mounted into pg-backup)
BACKUP_HOST_PATH=
BACKUP_HOUR_UTC=03
BACKUP_RETENTION_DAYS=30

# Dead-man's-switch UUID from healthchecks.io (free tier). Empty disables ping.
HEALTHCHECKS_BACKUP_UUID=

# --- Feature flags (lib/config/features.ts) ---
# Defaults match the SaaS deploy at kanblam.com. Self-hosters override:
#   LANDING_MODE=app
#   WAITLIST_ENABLED=false

# What `/` shows for logged-out visitors.
#   marketing → the SaaS landing page with waitlist signup (default)
#   app       → redirect logged-out visitors straight to /login (self-host)
LANDING_MODE=marketing

# Gates POST /api/waitlist and the landing-page waitlist form.
# Self-host deploys turn this off — no point collecting waitlist signups
# for a personal/family instance.
WAITLIST_ENABLED=true

# Reserved for the eventual Polar.sh billing integration. Off until
# billing actually ships.
BILLING_ENABLED=false

# --- Billing (Polar.sh) — hosted service only, all empty by default ---
# Billing is a hard no-op unless BILLING_ENABLED=true AND a Polar access token
# is set; self-hosters leave every value below blank. NEVER commit real tokens
# or product ids — these are placeholder names only; real values live in
# .env.prod / deploy secrets (see docs/CONFIGURATION.md → Billing).
#
# Polar environment. Defaults to "production" (api.polar.sh). Under Polar's
# current test/live-by-token model, a TEST-mode token also authenticates against
# production — so test-mode billing uses POLAR_ENV=production, gated by the token,
# not by a separate host. Set "sandbox" only to target the legacy isolated
# sandbox-api.polar.sh host. (anything other than the literal "sandbox" → production)
POLAR_ENV=
# Polar organization access token (test-mode token before go-live, live token
# at go-live). Empty → billing stays off even if BILLING_ENABLED is true (fail
# safe, logged once).
POLAR_ACCESS_TOKEN=
# Polar product ids per hosted tier + cadence (product ids only — no price ids,
# no per-currency vars; prices/regions are configured in Polar's dashboard).
# When BILLING_ENABLED=true, every id below must be set or billing errors loudly.
POLAR_PRODUCT_HOSTED_STANDARD_MONTHLY=
POLAR_PRODUCT_HOSTED_STANDARD_ANNUAL=
# Polar webhook signing secret (from the webhook endpoint config). Required when
# BILLING_ENABLED=true: the /api/billing/webhook route validates Standard-Webhooks
# signatures against it and fails closed (rejects every delivery) when it's empty.
POLAR_WEBHOOK_SECRET=

# --- Analytics (PostHog Cloud, optional) ---
# Server-injected into the root layout; passed as props to the client
# PostHogProvider. Empty values → provider is a no-op, no script loaded,
# no events captured. Self-host deploys leave both blank to opt out.
# Tracks public routes only (/, /docs/*, /login, /signup); the
# authenticated app (`(app)/*`) is deliberately never instrumented.
POSTHOG_KEY=
POSTHOG_HOST=https://eu.i.posthog.com

# ── Demo deployment (try.kanblam.com) ─────────────────────────────────────
# DEMO_MODE=1 turns this deployment into a Vikunja-style instant-demo box:
# /demo + POST /api/demo create throwaway, pre-seeded workspaces, and the
# cleanup-demo-workspaces cron reaps them after DEMO_TTL_HOURS (default 24).
# NEVER set DEMO_MODE=1 on the production tenant box.
DEMO_MODE=0
DEMO_TTL_HOURS=24
# On the PRODUCTION marketing site only: absolute URL of the demo box's
# /demo page. When set, the landing hero shows a "Try the live demo" button.
# DEMO_URL=https://try.kanblam.com/demo
